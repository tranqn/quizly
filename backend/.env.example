# Copy this file to ".env" and fill in your own values.
# Local development: the defaults below (DEBUG=True) are enough; just set
# GEMINI_API_KEY. Production: see the commented production block at the bottom.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Origins of the provided frontend, only needed when it is served from a
# different origin (cross-site). In the same-origin Docker deploy this is unused.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Quiz generation pipeline
# Gemini Flash API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base

# --- yt-dlp anti-bot (YouTube blocks datacenter IPs) ---------------------------
# Player clients to try (comma-separated). Leave EMPTY to let yt-dlp choose —
# forcing clients can break extraction (e.g. 'tv' now serves DRM-only formats).
# Only set this if a specific client is known to help your case.
YTDLP_PLAYER_CLIENTS=
# Proof-of-Origin token provider. In Docker this is set to the sidecar
# automatically (http://potoken:4416); leave blank for local dev.
YTDLP_POT_BASE_URL=
# Path to a Netscape cookies.txt exported from a *throwaway* Google account.
# In Docker, mount it under ./secrets and point here, e.g. /secrets/cookies.txt.
YTDLP_COOKIEFILE=
# Optional residential/rotating proxy, e.g. http://user:pass@host:port
YTDLP_PROXY=

# --- Production (uncomment / set when DEBUG=False) -----------------------------
# DEBUG=False
# SECRET_KEY=<a real long random string>
# DOMAIN=quizly.example.com
# ALLOWED_HOSTS=quizly.example.com
# CSRF_TRUSTED_ORIGINS=https://quizly.example.com
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SQLITE_PATH=/app/data/db.sqlite3
